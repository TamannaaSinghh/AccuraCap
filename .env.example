# Sanity CMS — public, read-only project identifiers
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Resend — for the contact form (server-only, never expose to client)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override the From address. Defaults to "AccuraCap <onboarding@resend.dev>".
# Once accuracap.com is verified in Resend, set this to e.g. "AccuraCap <noreply@accuracap.com>".
RESEND_FROM_ADDRESS=

# Optional: override the recipient. Defaults to "info@accuracap.com".
# While using Resend's sandbox (no verified domain), you MUST set this to the
# email you signed up to Resend with — it will refuse to deliver anywhere else.
CONTACT_TO_ADDRESS=
